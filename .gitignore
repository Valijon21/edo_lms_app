# ==========================================
#   edo_lms_app Professional .gitignore
# ==========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
ENV/
dist/
build/
*.spec

# --- Django ---
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_cdn/
media_cdn/
*.log
local_settings.py
.env
.env.*
.env.example

# --- Testing & Code Quality Caches ---
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/

# --- IDEs & Editors ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# --- Operating System Files ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# --- Large Media & Video Files ---
# These are too large for Git/GitHub and should be stored elsewhere
*.mp4
*.part
*.avi
*.mkv
*.mov

# --- Local Logs & Output Files ---
logs/
*.log

# --- Temporary & Scratch Files ---
# Developer scratch/test files
scratch_*.py
scratch_*.bat
check_*.py
test_whisper*.py
extract_*.py
get_*.py
make_*_admin.py

# Command outputs
*_out.txt
*_output.txt
output_*.txt
test_results.txt
tracked_output.txt
git_history.txt

# Temporary planning docs (use .kiro/specs instead)
implementation_plan*.md
project_status.md
sandbox-clone.md
simulator-plan.md
*-plan.md
kelajak.md
gamification-cases.md

# --- Graphify ---
graphify-out/

# --- AI Assistant Files (Private/Local Only) ---
# Kiro specs and agent configurations should NOT be in git
.kiro/
.agents/

# --- Database Files ---
db.sqlite3
db.sqlite3-journal